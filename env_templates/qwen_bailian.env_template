# TaleSeed .env template (Qwen via Alibaba Cloud Bailian / DashScope)
#
# Usage:
#   cp env_templates/qwen_bailian.env_template .env
#   # then edit .env and fill your secrets
#
# Notes:
# - Bailian provides an OpenAI-compatible Chat Completions endpoint.
# - This project reads QWEN_* variables when TALE_LLM_PROVIDER=qwen.
# - Bailian docs may call the key DASHSCOPE_API_KEY; here we store it in QWEN_API_KEY (or use TALE_LLM_API_KEY override).

TALE_LLM_PROVIDER=qwen

# Required (Bailian API Key, usually sk-xxxxx):
QWEN_API_KEY=sk-your-bailian-api-key

# Required: choose one base_url by region (examples from Bailian docs)
# Beijing:
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore:
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# US (Virginia):
# QWEN_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# Required: model name (example: qwen-plus)
QWEN_MODEL=qwen-plus

# Workflow options:
TALE_OUTPUT_DIR=output
TALE_MAX_RETRIES=3
