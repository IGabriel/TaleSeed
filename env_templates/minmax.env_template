# TaleSeed .env template (MiniMax)
#
# Usage:
#   cp env_templates/minmax.env_template .env
#   # then edit .env and fill your secrets
#
# Notes:
# - MiniMax is used via an OpenAI-compatible endpoint.

TALE_LLM_PROVIDER=minmax

MINMAX_API_KEY=sk-your-minmax-api-key
MINMAX_BASE_URL=https://your-minmax-openai-compatible-host/v1
MINMAX_MODEL=your-minmax-model-name

TALE_OUTPUT_DIR=output
TALE_MAX_RETRIES=3
