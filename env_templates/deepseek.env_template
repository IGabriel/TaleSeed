# TaleSeed .env template (DeepSeek)
#
# Usage:
#   cp env_templates/deepseek.env_template .env
#   # then edit .env and fill your secrets
#
# Notes:
# - DeepSeek is used via an OpenAI-compatible endpoint.
# - For non-OpenAI providers, TALE_LLM_BASE_URL and TALE_LLM_MODEL (or provider-specific ones) are required.

TALE_LLM_PROVIDER=deepseek

# Required:
DEEPSEEK_API_KEY=ds-your-deepseek-api-key

# Required: OpenAI-compatible base URL (check DeepSeek docs; commonly ends with /v1)
DEEPSEEK_BASE_URL=https://your-deepseek-openai-compatible-host/v1

# Required: model name (example only; use what your account supports)
DEEPSEEK_MODEL=deepseek-chat

# Workflow options:
TALE_OUTPUT_DIR=output
TALE_MAX_RETRIES=3
