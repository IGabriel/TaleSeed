# TaleSeed .env template (Grok / xAI)
#
# Usage:
#   cp env_templates/grok.env_template .env
#   # then edit .env and fill your secrets
#
# Notes:
# - Grok is used via an OpenAI-compatible endpoint.

TALE_LLM_PROVIDER=grok

GROK_API_KEY=sk-your-grok-api-key
GROK_BASE_URL=https://your-grok-openai-compatible-host/v1
GROK_MODEL=your-grok-model-name

TALE_OUTPUT_DIR=output
TALE_MAX_RETRIES=3
