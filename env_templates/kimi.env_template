# TaleSeed .env template (Kimi)
#
# Usage:
#   cp env_templates/kimi.env_template .env
#   # then edit .env and fill your secrets
#
# Notes:
# - Kimi is used via an OpenAI-compatible endpoint.

TALE_LLM_PROVIDER=kimi

KIMI_API_KEY=sk-your-kimi-api-key
KIMI_BASE_URL=https://your-kimi-openai-compatible-host/v1
KIMI_MODEL=your-kimi-model-name

TALE_OUTPUT_DIR=output
TALE_MAX_RETRIES=3
