# TaleSeed .env template (OpenAI)
#
# Usage:
#   cp env_templates/openai.env_template .env
#   # then edit .env and fill your secrets
#
# Notes:
# - .env is ignored by git via .gitignore (recommended).
# - If you set TALE_LLM_API_KEY / TALE_LLM_MODEL / TALE_LLM_BASE_URL, they override provider-specific vars.

TALE_LLM_PROVIDER=openai

# Required for provider=openai:
OPENAI_API_KEY=sk-your-openai-api-key

# Optional:
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Workflow options:
TALE_OUTPUT_DIR=output
TALE_MAX_RETRIES=3
